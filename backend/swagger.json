{
  "openapi": "3.0.0",
  "info": {
    "title": "Blog API",
    "description": "个人博客后端 API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "开发环境"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "summary": "健康检查",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/posts": {
      "get": {
        "summary": "获取文章列表",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "posts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "number" },
                          "title": { "type": "string" },
                          "excerpt": { "type": "string" },
                          "cover": { "type": "string" },
                          "created_at": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "创建文章",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "content", "excerpt", "slug"],
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" },
                  "excerpt": { "type": "string" },
                  "slug": { "type": "string" },
                  "cover": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "创建成功"
          },
          "400": {
            "description": "参数错误"
          }
        }
      }
    },
    "/api/posts/{id}": {
      "get": {
        "summary": "获取文章详情",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "post": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "number" },
                        "title": { "type": "string" },
                        "content": { "type": "string" },
                        "excerpt": { "type": "string" },
                        "slug": { "type": "string" },
                        "cover": { "type": "string" },
                        "views": { "type": "number" },
                        "created_at": { "type": "string" },
                        "updated_at": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "文章不存在"
          }
        }
      },
      "put": {
        "summary": "更新文章",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "content": { "type": "string" },
                  "excerpt": { "type": "string" },
                  "cover": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功"
          },
          "404": {
            "description": "文章不存在"
          }
        }
      },
      "delete": {
        "summary": "删除文章",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功"
          },
          "404": {
            "description": "文章不存在"
          }
        }
      }
    },
    "/api/moments": {
      "get": {
        "summary": "获取说说列表",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "moments": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "number" },
                          "content": { "type": "string" },
                          "image": { "type": "string" },
                          "likes": { "type": "number" },
                          "created_at": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "发布说说",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": { "type": "string" },
                  "image": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "发布成功"
          },
          "400": {
            "description": "参数错误"
          }
        }
      }
    },
    "/api/moments/{id}": {
      "get": {
        "summary": "获取说说详情",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "moment": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "number" },
                        "content": { "type": "string" },
                        "image": { "type": "string" },
                        "likes": { "type": "number" },
                        "created_at": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "说说不存在"
          }
        }
      },
      "put": {
        "summary": "更新说说",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string" },
                  "image": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功"
          },
          "404": {
            "description": "说说不存在"
          }
        }
      },
      "delete": {
        "summary": "删除说说",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功"
          },
          "404": {
            "description": "说说不存在"
          }
        }
      }
    },
    "/api/moments/{id}/like": {
      "post": {
        "summary": "点赞说说",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "点赞成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "moment": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "number" },
                        "content": { "type": "string" },
                        "image": { "type": "string" },
                        "likes": { "type": "number" },
                        "created_at": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "说说不存在"
          }
        }
      }
    }
  }
}
